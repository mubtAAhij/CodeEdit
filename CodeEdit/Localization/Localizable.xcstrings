    "settings.terminal.use-login-shell.help": {
      "comment": "Terminal use login shell help text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used used similar to Terminal.app."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used similar to Terminal.app."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Indica si se debe usar un shell de inicio de sesión al iniciar una sesión de terminal. De forma predeterminada, se usa un shell de inicio de sesión de manera similar a Terminal.app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启动终端会话时是否使用登录 shell。默认情况下，会使用登录 shell，与 Terminal.app 类似。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise ou non un shell de connexion au démarrage d'une session de terminal. Par défaut, un shell de connexion est utilisé, comme dans Terminal.app."
          }
        }
      }
    }
  }
}