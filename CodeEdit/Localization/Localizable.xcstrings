    "git.stash-uncommitted-changes-description": {
      "comment": "Stash uncommitted changes description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu repositorio local tiene cambios sin confirmar que deben guardarse en stash antes de continuar. Ingresa una descripción para tus cambios."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "你的本地仓库有未提交的更改，需要先贮藏才能继续。请为你的更改输入描述。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dépôt local contient des modifications non validées qui doivent être remisées avant de pouvoir continuer. Entrez une description pour vos modifications."
          }
        }
      }
    },
    "git.stash-description": {
      "comment": "Stash description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingresa una descripción para tus cambios en stash para que puedas referenciarlos más tarde. Los stashes aparecerán en el navegador de control de código fuente de tu repositorio."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "输入对贮藏更改的描述以便稍后引用。贮藏将出现在仓库的源代码管理导航器中。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez une description pour vos modifications remisées afin de pouvoir les retrouver ultérieurement. Les remises apparaîtront dans le navigateur de contrôle de code source de votre dépôt."
          }
        }
      }
    },
