          "stringUnit": {
            "state": "translated",
            "value": "La cinta de plegado de código te permite plegar regiones de código. Cuando el medianil está desactivado, la cinta de plegado está desactivada."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "代码折叠条可让你折叠代码区域。当边线停用时，折叠条也会停用。"
