    "file-manager.recovery.reopen-workspace": {
      "comment": "Recovery suggestion to reopen the workspace",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reopen the workspace to reindex the file system."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a abrir el espacio de trabajo para reindexar el sistema de archivos."
          }
