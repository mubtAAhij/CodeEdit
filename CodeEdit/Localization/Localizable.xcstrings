{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "file-manager.error.file-not-found": {
      "comment": "Error when a file is not found on disk",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File not found"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivo no encontrado"
          }
        }
      }
    },
    "file-manager.error.file-not-indexed": {
      "comment": "Error when a file is not indexed in the workspace",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File not found in CodeEdit"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivo no encontrado en CodeEdit"
          }
        }
      }
    },
    "file-manager.error.origin-not-found": {
      "comment": "Error when the origin file for an operation is not found",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to find origin file"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
