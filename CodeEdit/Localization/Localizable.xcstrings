      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code folding ribbon lets you fold regions of code. When the gutter is disabled, the folding ribbon is disabled."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "The code folding ribbon lets you fold regions of code. When the gutter is disabled, the folding ribbon is disabled."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El margen de plegado te permite plegar regiones de código. Cuando el medianil está desactivado, el margen de plegado está desactivado."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "折叠栏可让你折叠代码区域。当装订线停用时，折叠栏也会停用。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "La marge de pliage permet de replier des régions de code. Lorsque la gouttière est désactivée, la marge de pliage est désactivée."
          }
        }
      }
