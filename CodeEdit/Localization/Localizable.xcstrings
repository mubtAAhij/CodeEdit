  "strings": {
    "workspace.file-manager.error.file-not-found": {
      "comment": "Error when a file cannot be found on disk",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File not found"
          }
        }
      }
    },
    "workspace.file-manager.error.file-not-indexed": {
      "comment": "Error when a file is not indexed in CodeEdit's cache",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File not found in CodeEdit"
          }
        }
      }
    },
