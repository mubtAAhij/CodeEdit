      }
    },
    "file-manager.recovery.file-moved": {
      "comment": "Recovery suggestion when a file may have moved",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file may have moved during the operation, try again."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo pudo haberse movido durante la operación, intenta de nuevo."
          }
        }
      }
    },
    "file-manager.recovery.rename-or-remove": {
      "comment": "Recovery suggestion to rename or remove conflicting file",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a different file name or remove the conflicting file."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa un nombre de archivo diferente o elimina el archivo en conflicto."
          }
        }
      }
    },
    "file-manager.recovery.valid-filename": {
      "comment": "Recovery suggestion for valid file name requirements",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File names must not contain the : character and be less than 256 characters."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Los nombres de archivo no deben contener el carácter : ni superar los 256 caracteres."
          }
        }
      }
    },
