    "file.error.recovery.invalid-name": {
      "comment": "Recovery suggestion for invalid file name",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File names must not contain the : character and be less than 256 characters."
