    "source-control.stash.uncommitted-changes": {
      "comment": "Stash uncommitted changes message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu repositorio local tiene cambios sin confirmar que deben guardarse en stash antes de poder continuar. Ingresa una descripción para tus cambios."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "你的本地仓库有未提交的更改，需要先贮藏才能继续。为你的更改输入描述。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dépôt local contient des modifications non validées qui doivent être mises en remise avant de pouvoir continuer. Entrez une description pour vos modifications."
          }
        }
      }
    },
    "source-control.stash.description": {
      "comment": "Stash description message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingresa una descripción para tus cambios guardados en stash para poder referenciarlos más adelante. Los stashes aparecerán en el navegador de Control de Fuente de tu repositorio."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "输入贮藏更改的描述,以便稍后引用。贮藏将出现在仓库的源代码控制导航器中。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez une description pour vos modifications en remise afin de pouvoir vous y référer ultérieurement. Les remises apparaîtront dans le navigateur de contrôle de source pour votre dépôt."
          }
        }
      }
    },
