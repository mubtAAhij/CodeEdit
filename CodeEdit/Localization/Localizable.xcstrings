    "settings.extensions.lsp-info": {
      "comment": "CodeEdit/Features/Settings/Pages/Extensions/LanguageServersView.swift",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit usa el Mason Registry para la instalación de servidores de lenguaje. Para instalar un paquete, CodeEdit utiliza el gestor de paquetes indicado por el Mason Registry e instala una copia del servidor de lenguaje en Application Support.\n\nLa instalación de servidores de lenguaje aún es experimental, puede haber errores y este flujo puede cambiar con el tiempo."
          }
        }
      }
    },
    "settings.extensions.lsp-warning": {
      "comment": "CodeEdit/Features/Settings/Pages/Extensions/LanguageServersView.swift",
