    "git.ignored-files.description": {
      "comment": "Ignored files description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Patterns for files and folders that Git should ignore and not track. Applied globally to all repositories on your Mac. [Learn more...](https://git-scm.com/docs/gitignore)"
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Patterns for files and folders that Git should ignore and not track. Applied globally to all repositories on your Mac. [Learn more...](https://git-scm.com/docs/gitignore)"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrones para archivos y carpetas que Git debe ignorar y no rastrear. Se aplica globalmente a todos los repositorios en tu Mac. [Más información...](https://git-scm.com/docs/gitignore)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Git 应忽略且不跟踪的文件和文件夹的模式。全局应用于 Mac 上的所有仓库。[了解更多...](https://git-scm.com/docs/gitignore)"
          }
        },
        "fr-FR": {
