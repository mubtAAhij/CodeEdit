    "settings.language-servers.warning": {
      "comment": "Warning about experimental language server installation",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Language server installation is experimental. Use at your own risk."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Language server installation is experimental. Use at your own risk."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: La instalación de servidores de lenguaje es experimental. Usa esta función bajo tu propio riesgo."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "警告:语言服务器安装功能为实验性功能。使用风险自负。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avertissement : L'installation de serveur de langage est expérimentale. Utilisez-la à vos risques et périls."
          }
        }
      }
    },
    "settings.language-servers.info": {
      "comment": "Language server installation info text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit utiliza el Mason Registry para la instalación de servidores de lenguaje. Para instalar un paquete, CodeEdit usa el gestor de paquetes indicado por el Mason Registry e instala una copia del servidor de lenguaje en Application Support.\n\nLa instalación de servidores de lenguaje aún es experimental, puede haber errores y este flujo cambiará con el tiempo."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 使用 Mason Registry 来安装语言服务器。安装包时，CodeEdit 使用 Mason Registry 指定的包管理器，并在 Application Support 中安装语言服务器的副本。\n\n语言服务器安装功能仍处于实验阶段，可能存在错误，且此流程可能会随时间变化。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit utilise le registre Mason pour l'installation des serveurs de langage. Pour installer un paquet, CodeEdit utilise le gestionnaire de paquets indiqué par le registre Mason et installe une copie du serveur de langage dans Application Support.\n\nL'installation des serveurs de langage est encore expérimentale, des bogues peuvent survenir et ce processus est susceptible d'évoluer."
          }
        }
      }
    },
