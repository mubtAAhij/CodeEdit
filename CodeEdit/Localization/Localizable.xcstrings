    },
    "file.error.recovery.rename": {
      "comment": "Recovery suggestion when destination exists",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a different file name or remove the conflicting file."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa un nombre de archivo diferente o elimina el archivo en conflicto."
