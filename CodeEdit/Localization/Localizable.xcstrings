    "settings.lsp.experimental-warning": {
      "comment": "Warning about experimental LSP installation",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Language server installation is experimental. Use at your own risk."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Language server installation is experimental. Use at your own risk."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: La instalación del servidor de lenguaje es experimental. Úsala bajo tu propio riesgo."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "警告:语言服务器安装功能为实验性功能。使用风险自负。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avertissement : L'installation de serveur de langage est expérimentale. Utilisez à vos risques et périls."
          }
        }
      }
    },
    "settings.lsp.installation-info": {
      "comment": "Information about LSP installation process",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit utiliza el Registro de Mason para la instalación de servidores de lenguaje. Para instalar un paquete, CodeEdit usa el administrador de paquetes indicado por el Registro de Mason e instala una copia del servidor de lenguaje en Application Support.\n\nLa instalación de servidores de lenguaje aún es experimental, puede haber errores y este flujo cambiará con el tiempo."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 使用 Mason Registry 进行语言服务器安装。安装包时,CodeEdit 会使用 Mason Registry 指定的包管理器,并在 Application Support 中安装语言服务器的副本。\n\n语言服务器安装功能仍处于实验阶段,可能存在错误,此流程预计会随时间变化。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit utilise le registre Mason pour l'installation des serveurs de langage. Pour installer un paquet, CodeEdit utilise le gestionnaire de paquets indiqué par le registre Mason et installe une copie du serveur de langage dans Application Support.\n\nL'installation des serveurs de langage est encore expérimentale, des bugs peuvent survenir et ce processus est susceptible d'évoluer."
          }
        }
      }
    },
