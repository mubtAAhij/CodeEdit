    "stash.uncommitted-changes-description": {
      "comment": "Description for stashing uncommitted changes",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu repositorio local tiene cambios sin confirmar que deben guardarse en stash antes de continuar. Ingresa una descripción para tus cambios."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "你的本地仓库有未提交的更改，需要先贮藏才能继续。请输入对你的更改的描述。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dépôt local contient des modifications non validées qui doivent être remisées avant de continuer. Entrez une description pour vos modifications."
          }
        }
      }
    },
    "stash.description": {
      "comment": "Description for stashing changes",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingresa una descripción para los cambios guardados en stash para que puedas referenciarlos más adelante. Los stashes aparecerán en el navegador de control de versiones de tu repositorio."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "为您贮藏的更改输入描述,以便日后引用。贮藏将显示在您仓库的版本控制导航器中。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez une description pour votre remise afin de pouvoir la référencer ultérieurement. Les remises apparaîtront dans le navigateur de contrôle de version pour votre dépôt."
          }
        }
      }
    },
