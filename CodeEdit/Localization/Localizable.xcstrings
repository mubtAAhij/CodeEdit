    "workspace.file-manager.recovery.valid-filename": {
      "comment": "Recovery suggestion for invalid file name error",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File names must not contain the : character and be less than 256 characters."
