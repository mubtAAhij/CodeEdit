    },
    "filemanager.error.recovery.destination-exists": {
      "comment": "Recovery suggestion for destination exists error",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a different file name or remove the conflicting file."
