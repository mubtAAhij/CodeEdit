        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Define si se usa o no un shell de inicio de sesión al iniciar una sesión de terminal. De forma predeterminada, se usa un shell de inicio de sesión similar a Terminal.app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启动终端会话时是否使用登录 shell。默认情况下，会使用登录 shell，与 Terminal.app 的行为类似。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliser ou non un shell de connexion lors du démarrage d'une session terminal. Par défaut, un shell de connexion est utilisé de manière similaire à Terminal.app."
          }
        }
      }
