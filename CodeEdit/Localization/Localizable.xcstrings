    "settings.search.exclude-description": {
      "comment": "Exclude section description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add glob patterns to exclude matching files and folders from searches and open quickly. This will inherit glob patterns from the Exclude from Project setting."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Add glob patterns to exclude matching files and folders from searches and open quickly. This will inherit glob patterns from the Exclude from Project setting."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega patrones glob para excluir archivos y carpetas coincidentes de las búsquedas y la apertura rápida. Esto heredará los patrones glob de la configuración Excluir del Proyecto."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "添加 glob 模式以从搜索和快速打开中排除匹配的文件和文件夹。这将继承\\\"从项目中排除\\\"设置中的 glob 模式。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter des glob patterns pour exclure les fichiers et dossiers correspondants des recherches et de l'ouverture rapide. Cette option héritera des glob patterns du réglage Exclure du projet."
          }
        }
      }
    },
