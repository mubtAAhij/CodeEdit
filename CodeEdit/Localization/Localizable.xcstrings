    "file.error.recovery.moved": {
      "comment": "Recovery suggestion when file may have moved",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file may have moved during the operation, try again."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que el archivo se haya movido durante la operación, intenta de nuevo."
