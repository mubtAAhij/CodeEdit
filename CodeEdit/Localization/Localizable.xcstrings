    "workspace.file-manager.recovery.file-moved": {
      "comment": "Recovery suggestion for file not found errors",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file may have moved during the operation, try again."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo puede haberse movido durante la operación, intenta de nuevo."
