      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit makes use of the Mason Registry for language server installation. To install a package, CodeEdit uses the package manager directed by the Mason Registry, and installs a copy of the language server in Application Support.\n\nLanguage server installation is still experimental, there may be bugs and expect this flow to change over time."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit utiliza el Mason Registry para la instalación de language servers. Para instalar un paquete, CodeEdit usa el gestor de paquetes indicado por el Mason Registry e instala una copia del language server en Application Support.\n\nLa instalación de language servers aún es experimental, puede haber errores y este flujo puede cambiar con el tiempo."
          }
        }
      }
    },
