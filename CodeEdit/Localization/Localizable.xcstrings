      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a branch from the current branch and switch to it. All uncommited changes will be preserved on the new branch."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a branch from the current branch and switch to it. All uncommited changes will be preserved on the new branch."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea una rama desde la rama actual y cambia a ella. Todos los cambios no confirmados se preservarán en la rama nueva."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "从当前分支创建一个分支并切换到该分支。所有未提交的更改将保留在新分支上。"
          }
