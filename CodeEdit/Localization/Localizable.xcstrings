    "settings.terminal.shell-integration.help": {
      "comment": "Shell integration help text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit permite integrar shells comunes como Bash y Zsh. Esto habilita funciones como la detección de título de terminal."
          }
        },
        "zh-CN": {
