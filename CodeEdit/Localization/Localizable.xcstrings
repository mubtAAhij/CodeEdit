    "settings.warning-characters.description": {
      "comment": "Description of warning characters feature",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit can help identify invisible or ambiguous characters, such as zero-width spaces, directional quotes, and more. These will appear with a red block highlighting them. You can disable characters or add more here."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit can help identify invisible or ambiguous characters, such as zero-width spaces, directional quotes, and more. These will appear with a red block highlighting them. You can disable characters or add more here."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit puede ayudar a identificar caracteres invisibles o ambiguos, como espacios de ancho cero, comillas direccionales y más. Estos aparecerán con un bloque rojo que los resalta. Puedes desactivar caracteres o agregar más aquí."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 可以帮助识别不可见或有歧义的字符,例如零宽空格、方向引号等。这些字符将以红色方块高亮显示。您可以在此处停用字符或添加更多字符。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit peut vous aider à identifier les caractères invisibles ou ambigus, tels que les espaces sans chasse, les guillemets directionnels, etc. Ceux-ci apparaîtront avec un bloc rouge les mettant en surbrillance. Vous pouvez désactiver des caractères ou en ajouter d'autres ici."
          }
        }
      }
    },
