    "settings.terminal.shell-integration.help": {
      "comment": "Terminal shell integration help text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit admite la integración con shells comunes como Bash y Zsh. Esto habilita funciones como la detección de título de terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 支持与 Bash 和 Zsh 等常见 shell 集成。这将启用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit prend en charge l'intégration avec les shells courants tels que Bash et Zsh. Cela active des fonctionnalités comme la détection du titre du terminal."
          }
        }
      }
    },
    "settings.terminal.shell-integration.warning": {
      "comment": "Terminal shell integration disabled warning",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: Desactivar la integración desactiva funciones como la detección de títulos de terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "警告：停用集成会禁用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Attention : Désactiver l'intégration désactive des fonctionnalités telles que la détection du titre du terminal."
          }
        }
      }
    },
