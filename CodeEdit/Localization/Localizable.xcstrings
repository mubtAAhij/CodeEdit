    "filemanager.error.recovery.file-moved": {
      "comment": "Recovery suggestion for file not found error",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file may have moved during the operation, try again."
