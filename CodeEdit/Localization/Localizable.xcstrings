    "file.error.recovery.reindex": {
      "comment": "Recovery suggestion for file not indexed",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reopen the workspace to reindex the file system."
