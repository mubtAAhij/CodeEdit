    "text-editing.show-minimap.help": {
      "comment": "Help text for show minimap toggle",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The minimap gives you a high-level summary of your source code, with controls to quickly navigate your document."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "The minimap gives you a high-level summary of your source code, with controls to quickly navigate your document."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El minimapa proporciona un resumen de alto nivel de tu código fuente, con controles para navegar rápidamente tu documento."
          }
        },
        "zh-CN": {
          "stringUnit": {
