      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code folding ribbon lets you fold regions of code. When the gutter is disabled, the folding ribbon is disabled."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "The code folding ribbon lets you fold regions of code. When the gutter is disabled, the folding ribbon is disabled."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La cinta de plegado de código te permite plegar regiones de código. Cuando el margen está desactivado, la cinta de plegado está desactivada."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "代码折叠栏让你可以折叠代码区域。当边栏被禁用时，代码折叠栏也会被禁用。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le ruban de pliage de code vous permet de replier des régions de code. Lorsque la gouttière est désactivée, le ruban de pliage est désactivé."
          }
        }
      }
    },
