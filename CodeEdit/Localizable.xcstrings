            "value": "Usar Shell de Inicio de Sesión"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "使用登录 Shell"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliser un shell de connexion"
          }
        }
      }
    },
    "settings.terminal.use-login-shell.help": {
      "comment": "Use login shell help text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used used similar to Terminal.app."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used similar to Terminal.app."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Si se debe usar un shell de inicio de sesión o no al iniciar una sesión de terminal. De manera predeterminada, se usa un shell de inicio de sesión similar a Terminal.app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "启动终端会话时是否使用登录 Shell。默认使用登录 Shell，与 Terminal.app 相似。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliser ou non un shell de connexion lors du démarrage d'une session de terminal. Par défaut, un shell de connexion est utilisé de manière similaire à Terminal.app."
          }
        }
      }
    }
  }
}