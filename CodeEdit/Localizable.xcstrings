    "settings.terminal.shell-integration.warning": {
      "comment": "Shell integration warning message",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: Desactivar la integración desactiva funciones como la detección de título de terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "警告：停用集成将停用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avertissement : La désactivation de l'intégration désactive des fonctionnalités telles que la détection du titre du terminal."
          }
        }
      }
    },
    "settings.terminal.use-login-shell": {
      "comment": "Use login shell toggle label",
      "extractionState": "manual",
      "localizations": {
        "en": {
