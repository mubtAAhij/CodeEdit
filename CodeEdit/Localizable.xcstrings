        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrones para archivos y carpetas que Git debe ignorar y no rastrear. Se aplica globalmente a todos los repositorios en tu Mac. [Más información...](https://git-scm.com/docs/gitignore)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Git 应忽略和不跟踪的文件和文件夹的模式。全局应用于 Mac 上的所有仓库。[了解更多...](https://git-scm.com/docs/gitignore)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Motifs pour les fichiers et dossiers que Git doit ignorer et ne pas suivre. Appliqués globalement à tous les dépôts sur votre Mac. [En savoir plus...](https://git-scm.com/docs/gitignore)"
          }
        }
      }
    },
