          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz copias de seguridad de tus archivos, colabora con otros y etiqueta tus versiones. [Más información...](https://developer.apple.com/documentation/xcode/source-control-management)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "备份您的文件，与他人协作，并标记您的发布版本。[了解更多...](https://developer.apple.com/documentation/xcode/source-control-management)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sauvegardez vos fichiers, collaborez avec d'autres et étiquetez vos versions. [En savoir plus...](https://developer.apple.com/documentation/xcode/source-control-management)"
          }
