    "terminal-settings.use-login-shell.help": {
      "comment": "Use login shell help tooltip",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used used similar to Terminal.app."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used used similar to Terminal.app."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Si se debe usar o no un shell de inicio de sesión al iniciar una sesión de terminal. De forma predeterminada, se usa un shell de inicio de sesión similar a Terminal.app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "设置启动终端会话时是否使用登录 Shell。默认情况下，会使用登录 Shell，这与 Terminal.app 的行为类似。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliser ou non un shell de connexion lors du démarrage d'une session de terminal. Par défaut, un shell de connexion est utilisé de manière similaire à Terminal.app."
          }
        }
      }
    },
