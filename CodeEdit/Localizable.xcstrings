        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back up your files, collaborate with others, and tag your releases. [Learn more...](https://developer.apple.com/documentation/xcode/source-control-management)"
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
