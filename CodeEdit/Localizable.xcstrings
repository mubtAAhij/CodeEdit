    "terminal-settings.shell-integration.help": {
      "comment": "Shell integration help tooltip",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit es compatible con la integración de shells comunes como Bash y Zsh. Esto habilita funciones como la detección de título de terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 支持与 Bash 和 Zsh 等常用 Shell 集成。这将启用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit prend en charge l'intégration avec les shells courants tels que Bash et Zsh. Cela permet des fonctionnalités comme la détection du titre de terminal."
          }
        }
      }
    },
    "terminal-settings.shell-integration.warning": {
      "comment": "Warning about disabling shell integration",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: Desactivar la integración desactiva funciones como la detección de título del terminal."
