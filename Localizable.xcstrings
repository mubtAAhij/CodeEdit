    "source-control.new-branch.description": {
      "comment": "Description explaining new branch creation",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a branch from the current branch and switch to it. All uncommited changes will be preserved on the new branch."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Crear una rama desde la rama actual y cambiar a ella. Todos los cambios sin confirmar se preservarán en la nueva rama."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "从当前分支创建一个分支并切换至该分支。所有未提交的更改将保留在新分支上。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Créer une branche à partir de la branche actuelle et y basculer. Toutes les modifications non validées seront conservées sur la nouvelle branche."
          }
        }
      }
    },
