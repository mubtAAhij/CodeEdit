    "settings.terminal.use-login-shell-help": {
      "comment": "Help text explaining login shell option",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whether or not to use a login shell when starting a terminal session. By default, a login shell is used used similar to Terminal.app."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Si se debe usar o no un shell de inicio de sesión al iniciar una sesión de terminal. Por defecto, se usa un shell de inicio de sesión similar a Terminal.app."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "在启动终端会话时是否使用登录 Shell。默认情况下，使用登录 Shell，类似于 Terminal.app。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Indique s'il faut utiliser un shell de connexion lors du démarrage d'une session terminal. Par défaut, un shell de connexion est utilisé, similaire à Terminal.app."
          }
        }
      }
    },
