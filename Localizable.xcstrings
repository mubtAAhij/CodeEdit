    "settings.text-editing.folding-ribbon-help": {
      "comment": "Help text for show code folding ribbon toggle",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code folding ribbon lets you fold regions of code. When the gutter is disabled, the folding ribbon is disabled."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La cinta de plegado de código te permite plegar regiones de código. Cuando el margen está deshabilitado, la cinta de plegado está deshabilitada."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "代码折叠功能区允许您折叠代码区域。当边栏已禁用时，折叠功能区也会被禁用。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le ruban de pliage de code vous permet de plier des régions de code. Lorsque la gouttière est désactivée, le ruban de pliage est désactivé."
          }
        }
      }
    },
