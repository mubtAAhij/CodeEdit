    "feedback.issue-body": {
      "comment": "Template for feedback issue body with description, steps, expectation, and actual result",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "**Description**\\n\\n\\(description)\\n\\n**Steps to Reproduce**\\n\\n\\(steps ?? notApplicable)\\n\\n**What did you expect to happen?**\\n\\n\\(expectation ?? notApplicable)\\n\\n**What actually happened?**\\n\\n\\(actuallyHappened ?? notApplicable)"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "**Descripción**\\n\\n\\(description)\\n\\n**Pasos para reproducir**\\n\\n\\(steps ?? notApplicable)\\n\\n**¿Qué esperabas que sucediera?**\\n\\n\\(expectation ?? notApplicable)\\n\\n**¿Qué sucedió realmente?**\\n\\n\\(actuallyHappened ?? notApplicable)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "**描述**\\n\\n\\(description)\\n\\n**复现步骤**\\n\\n\\(steps ?? notApplicable)\\n\\n**期望结果是什么？**\\n\\n\\(expectation ?? notApplicable)\\n\\n**实际结果是什么？**\\n\\n\\(actuallyHappened ?? notApplicable)"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "**Description**\\n\\n\\(description)\\n\\n**Étapes pour reproduire**\\n\\n\\(steps ?? notApplicable)\\n\\n**Qu'attendiez-vous ?**\\n\\n\\(expectation ?? notApplicable)\\n\\n**Que s'est-il réellement passé ?**\\n\\n\\(actuallyHappened ?? notApplicable)"
          }
        }
      }
    },
