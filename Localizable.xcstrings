          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrones para archivos y carpetas que Git debe ignorar y no rastrear. Se aplican globalmente a todos los repositorios en tu Mac. [Más información...](https://git-scm.com/docs/gitignore)"
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
