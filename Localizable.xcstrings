        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les fichiers du dépôt local passeront de la branche actuelle (« \\(sourceControlManager.currentBranch?.name ?? \\\"\\\") ») à « \\(branch.name) »."
