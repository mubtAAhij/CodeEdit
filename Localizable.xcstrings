    "settings.search.exclude.description": {
      "comment": "Description of how exclude patterns work in search settings",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add glob patterns to exclude matching files and folders from searches and open quickly. This will inherit glob patterns from the Exclude from Project setting."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar patrones glob para excluir archivos y carpetas coincidentes de las búsquedas y abrir rápidamente. Esto heredará patrones glob de la configuración Excluir del proyecto."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "添加 glob 模式以从搜索和快速打开中排除匹配的文件和文件夹。这将继承\\\"从项目中排除\\\"设置中的 glob 模式。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter des motifs glob pour exclure les fichiers et dossiers correspondants des recherches et d'Ouvrir rapidement. Cela héritera des motifs glob du paramètre Exclure du projet."
          }
        }
      }
    },
    "settings.search.no-excluded-patterns": {
      "comment": "Message shown when no glob patterns are excluded",
      "extractionState": "manual",
      "localizations": {
        "en": {
