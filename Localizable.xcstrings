    "settings.terminal.shell-integration-help": {
      "comment": "Help text explaining shell integration",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit supports integrating with common shells such as Bash and Zsh. This enables features like terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit admite la integración con shells comunes como Bash y Zsh. Esto habilita características como la detección del título del terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit 支持与常见 Shell（如 Bash 和 Zsh）集成。这可以启用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeEdit prend en charge l'intégration avec les shells courants tels que Bash et Zsh. Cela active des fonctionnalités comme la détection du titre du terminal."
          }
        }
      }
    },
    "settings.terminal.shell-integration-warning": {
      "comment": "Warning text when shell integration is disabled",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Disabling integration disables features such as terminal title detection."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertencia: Desactivar la integración desactiva características como la detección del título del terminal."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "警告：禁用集成将禁用终端标题检测等功能。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Avertissement : La désactivation de l'intégration désactive des fonctionnalités telles que la détection du titre du terminal."
          }
        }
      }
    },
    "settings.terminal.toggle.use-login-shell": {
      "comment": "Toggle for using login shell",
      "extractionState": "manual",
      "localizations": {
        "en": {
