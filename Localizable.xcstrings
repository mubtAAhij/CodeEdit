        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "小地图为您提供源代码的概览，通过控件可快速导航您的文档。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "La minimap fournit un aperçu général de votre code source, avec des commandes pour naviguer rapidement dans votre document."
          }
        }
      }
    },
