    "source-control.stash.description-required": {
      "comment": "Description when stashing is required before continuing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local repository has uncommitted changes that need to be stashed before you can continue. Enter a description for your changes."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu repositorio local tiene cambios sin confirmar que deben guardarse temporalmente antes de continuar. Ingresa una descripción para tus cambios."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "您的本地仓库有未提交的更改需要暂存才能继续。请为您的更改输入描述。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dépôt local contient des modifications non validées qui doivent être remisées avant de continuer. Entrez une description pour vos modifications."
          }
        }
      }
    },
    "source-control.stash.description-optional": {
      "comment": "Description for optional stashing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a description for your stashed changes so you can reference them later. Stashes will appear in the Source Control navigator for your repository."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingrese una descripción para sus cambios guardados para poder consultarlos más tarde. Los cambios guardados aparecerán en el navegador de Control de código fuente de su repositorio."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "为您暂存的更改输入描述，以便稍后引用。暂存项将显示在仓库的源代码管理导航器中。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez une description pour vos modifications remisées afin de pouvoir vous y référer plus tard. Les remises apparaîtront dans le navigateur Contrôle de source de votre dépôt."
          }
        }
      }
    },
