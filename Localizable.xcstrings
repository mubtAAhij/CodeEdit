    "settings.text-editing.minimap-help": {
      "comment": "Help text for show minimap toggle",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The minimap gives you a high-level summary of your source code, with controls to quickly navigate your document."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El minimapa te ofrece un resumen general de tu código fuente, con controles para navegar rápidamente por tu documento."
          }
        },
        "zh-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "缩略图为您提供源代码的高级概览，使用控件可快速导航文档。"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "La minicarte vous donne un aperçu général de votre code source, avec des contrôles pour naviguer rapidement dans votre document."
